
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /players/{playerId} {
      allow read: if true;
      allow write: if false; // Only admin via console/internal tools for now
    }
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true; // In production, add auth checks
    }
    match /ads/{adId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true; // In production, add auth checks
    }
  }
}
